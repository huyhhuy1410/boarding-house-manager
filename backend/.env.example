PORT=5000

# Chuỗi kết nối Database PostgreSQL (Ví dụ từ Supabase hoặc Postgres cục bộ)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boarding_house?schema=public"

# Token Bot Telegram (Nhận từ @BotFather trên Telegram)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# ID Telegram của riêng bạn để bảo mật (chỉ cho phép lệnh từ tài khoản của bạn)
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"
